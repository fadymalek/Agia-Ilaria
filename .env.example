# انسخ هذا الملف إلى .env واملأ القيم (للتشغيل المحلي فقط)

# رابط قاعدة بيانات Postgres (من Neon أو Render)
DATABASE_URL=postgresql://user:password@host/dbname

# مفتاح سري لتشفير الجلسات — استخدم نصاً عشوائياً طويلاً
SESSION_SECRET=change-this-to-a-long-random-string

# كلمة سر المسؤول الأولى (تُستخدم مرة واحدة عند أول تشغيل لإنشاء حساب admin)
ADMIN_PASSWORD=admin123

# البيئة
NODE_ENV=production
