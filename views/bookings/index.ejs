<%- include('../partials/head', { title: 'الحجوزات' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid py-4 px-4 fade-up">
  <%- include('../partials/flash') %>

  <!-- تذكير بتغيير كلمة المرور الافتراضية -->
  <% if (user && user.needsPwChange) { %>
    <a href="/account" class="alert d-flex align-items-center gap-2 border-0 shadow-sm text-decoration-none" style="background:#FDECEA;color:#B71C1C;border-right:5px solid #E53935 !important;">
      <i class="bi bi-shield-exclamation fs-5"></i>
      <div class="fw-700">للأمان: غيّر كلمة المرور الافتراضية — اضغط هنا</div>
    </a>
  <% } %>

  <!-- Alerts: today + pending -->
  <% if (typeof todayCount !== 'undefined' && todayCount > 0) { %>
    <div class="alert d-flex align-items-center gap-2 border-0 shadow-sm" style="background:#FFF8E1;color:#8B6914;border-right:5px solid var(--gold) !important;">
      <i class="bi bi-bell-fill fs-5" style="color:var(--gold);"></i>
      <div class="fw-700">عندك <%= todayCount %> حجز عليه الدور النهاردة 👇</div>
    </div>
  <% } %>
  <% if (typeof pendingCount !== 'undefined' && pendingCount > 0) { %>
    <a href="/bookings?status=pending" class="alert d-flex align-items-center gap-2 border-0 shadow-sm text-decoration-none" style="background:#FFF3E0;color:#E65100;border-right:5px solid #F57F17 !important;">
      <i class="bi bi-hourglass-split fs-5" style="color:#F57F17;"></i>
      <div class="fw-700">عندك <%= pendingCount %> طلب حجز في انتظار الموافقة — اضغط للمراجعة</div>
    </a>
  <% } %>

  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title"><i class="bi bi-calendar-check"></i>لوحة الحجوزات</h1>
    <div class="d-flex gap-2">
      <a href="/bookings/new?type=retreat" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-moon-stars-fill me-1"></i>خلوة جديدة
      </a>
      <a href="/bookings/new?type=spiritual_day" class="btn btn-success rounded-pill px-4">
        <i class="bi bi-brightness-high-fill me-1"></i>يوم روحي
      </a>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-4 col-lg">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#C4963A,#8B6914);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#FFF3E0;">
            <i class="bi bi-calendar3" style="color:#C4963A;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#C4963A,#8B6914);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.total %>
          </div>
          <div class="stat-label">إجمالي الحجوزات</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/bookings?type=retreat" class="text-decoration-none">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#1565C0,#0D47A1);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#E3F2FD;">
            <i class="bi bi-moon-stars-fill" style="color:#1565C0;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#1565C0,#0D47A1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.retreat %>
          </div>
          <div class="stat-label">خلوات جماعية</div>
        </div>
      </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/bookings?type=individual_retreat" class="text-decoration-none">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#6A1B9A,#4A148C);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#F3E5F5;">
            <i class="bi bi-person-hearts" style="color:#6A1B9A;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#6A1B9A,#4A148C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.individual %>
          </div>
          <div class="stat-label">خلوات فردية</div>
        </div>
      </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/bookings?type=spiritual_day" class="text-decoration-none">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#2E7D32,#1B5E20);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#E8F5E9;">
            <i class="bi bi-brightness-high-fill" style="color:#2E7D32;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#2E7D32,#1B5E20);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.spiritual %>
          </div>
          <div class="stat-label">أيام روحية</div>
        </div>
      </div>
      </a>
    </div>
    <div class="col-6 col-md-4 col-lg">
      <a href="/bookings?status=pending" class="text-decoration-none">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#F57F17,#E65100);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#FFF8E1;">
            <i class="bi bi-clock-history" style="color:#F57F17;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#F57F17,#E65100);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.pending %>
          </div>
          <div class="stat-label">في الانتظار</div>
        </div>
      </div>
      </a>
    </div>
  </div>

  <!-- Filter -->
  <div class="card filter-card mb-4">
    <div class="card-body">
      <form method="GET" action="/bookings" class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">بحث</label>
          <div class="position-relative">
            <i class="bi bi-search position-absolute" style="right:12px;top:50%;transform:translateY(-50%);color:#BBA880;z-index:5;"></i>
            <input type="text" class="form-control" name="search" value="<%= query.search || '' %>"
              placeholder="كنيسة، كاهن، رقم حجز..." style="padding-right:38px;">
          </div>
        </div>
        <div class="col-md-2">
          <label class="form-label">النوع</label>
          <select class="form-select" name="type">
            <option value="">الكل</option>
            <option value="retreat" <%= query.type==='retreat'?'selected':'' %>>خلوة جماعية</option>
            <option value="individual_retreat" <%= query.type==='individual_retreat'?'selected':'' %>>خلوة فردية</option>
            <option value="spiritual_day" <%= query.type==='spiritual_day'?'selected':'' %>>يوم روحي</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">الحالة</label>
          <select class="form-select" name="status">
            <option value="">الكل</option>
            <option value="confirmed" <%= query.status==='confirmed'?'selected':'' %>>مؤكد</option>
            <option value="pending" <%= query.status==='pending'?'selected':'' %>>انتظار</option>
            <option value="cancelled" <%= query.status==='cancelled'?'selected':'' %>>ملغي</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">من تاريخ</label>
          <input type="date" class="form-control" name="from" value="<%= query.from || '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">إلى تاريخ</label>
          <input type="date" class="form-control" name="to" value="<%= query.to || '' %>">
        </div>
        <div class="col-md-1">
          <div class="d-flex gap-1">
            <button type="submit" class="btn btn-gold flex-fill" title="بحث"><i class="bi bi-search"></i></button>
            <a href="/bookings" class="btn btn-outline-secondary flex-fill" title="مسح"><i class="bi bi-x-lg"></i></a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Quick Links to public forms -->
  <div class="d-flex align-items-center gap-2 mb-3 flex-wrap quick-links">
    <small class="text-muted fw-semibold me-1"><i class="bi bi-share me-1"></i>روابط الحجز للكنائس:</small>
    <a href="/forms/retreat" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3">
      <i class="bi bi-moon-stars me-1"></i>فورم خلوة جماعية
    </a>
    <a href="/forms/individual" target="_blank" class="btn btn-sm rounded-pill px-3" style="border:1px solid #6A1B9A;color:#6A1B9A;">
      <i class="bi bi-person-hearts me-1"></i>فورم خلوة فردية
    </a>
    <a href="/forms/spiritual-day" target="_blank" class="btn btn-sm btn-outline-success rounded-pill px-3">
      <i class="bi bi-sun me-1"></i>فورم يوم روحي
    </a>
    <%
      const _qs = Object.entries(query || {}).filter(([k, v]) => v).map(([k, v]) => k + '=' + encodeURIComponent(v)).join('&');
    %>
    <a href="/bookings/export<%= _qs ? '?' + _qs : '' %>" class="btn btn-sm btn-success rounded-pill px-3 ms-auto">
      <i class="bi bi-file-earmark-excel me-1"></i>تصدير Excel
    </a>
    <a href="/bookings/trash" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
      <i class="bi bi-trash3 me-1"></i>المحذوفات
    </a>
    <a href="/reports" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
      <i class="bi bi-bar-chart-line me-1"></i>التقرير الأسبوعي
    </a>
  </div>

  <!-- Empty state -->
  <% if (bookings.length === 0) { %>
    <div class="card">
      <div class="card-body text-center py-5 text-muted">
        <i class="bi bi-inbox" style="font-size:3rem;color:#D4B870;"></i>
        <p class="mt-3 mb-1 fw-semibold">لا توجد حجوزات</p>
        <small>ابدأ بإضافة حجز جديد</small>
      </div>
    </div>
  <% } else { %>

  <!-- ===== جدول (ديسكتوب) ===== -->
  <div class="card d-none d-lg-block">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th class="pe-3">رقم الحجز</th>
              <th>اسم الكنيسة</th>
              <th>النوع</th>
              <th>التاريخ</th>
              <th>الكاهن</th>
              <th>الفئة</th>
              <th class="text-center">العدد</th>
              <th>المدفوع</th>
              <th>المتبقي</th>
              <th>الحالة</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(b => { %>
            <tr class="<%= b._when==='today' ? 'row-today' : (b._when==='past' ? 'row-past' : '') %>">
              <td class="pe-3" data-label="رقم الحجز">
                <span class="booking-num"><%= b.booking_number %></span>
                <% if (b.source === 'form') { %>
                  <span class="badge ms-1" style="background:#EDE0FF;color:#6A0DAD;font-size:0.68rem;">أونلاين</span>
                <% } %>
              </td>
              <td class="td-title">
                <div class="fw-700" style="font-size:1rem;"><%= b.church_name %></div>
                <% if (b.sector_name) { %><div class="text-muted" style="font-size:0.82rem;"><%= b.sector_name %></div><% } %>
              </td>
              <td data-label="النوع">
                <% const ti = typeInfo(b.booking_type); %>
                <span class="badge" style="background:<%= ti.bg %>;color:<%= ti.color %>;">
                  <i class="bi <%= ti.icon %> me-1"></i><%= ti.label %>
                </span>
              </td>
              <td data-label="التاريخ" style="font-size:0.9rem;">
                <% if (isStayType(b.booking_type) && b.start_date) { %>
                  <div><i class="bi bi-calendar2 me-1 text-muted"></i><%= b.start_date %></div>
                  <div class="text-muted"><i class="bi bi-arrow-left me-1"></i><%= b.end_date || '' %></div>
                <% } else if (b.event_date) { %>
                  <div><i class="bi bi-calendar2 me-1 text-muted"></i><%= b.event_date %></div>
                  <% if (b.start_time) { %>
                    <div class="text-muted" style="font-size:0.82rem;"><i class="bi bi-clock me-1"></i><%= b.start_time %>-<%= b.end_time||'' %></div>
                  <% } %>
                <% } else { %><span class="text-muted">-</span><% } %>
                <% if (b._when === 'today') { %>
                  <span class="badge mt-1 when-today"><i class="bi bi-bell-fill me-1"></i>النهاردة</span>
                <% } else if (b._when === 'past') { %>
                  <span class="badge mt-1 when-past"><i class="bi bi-check2-all me-1"></i>خلص</span>
                <% } else if (b._when === 'upcoming') { %>
                  <span class="badge mt-1 when-upcoming"><i class="bi bi-hourglass-top me-1"></i>قادم</span>
                <% } %>
              </td>
              <td data-label="الكاهن" style="font-size:0.92rem;"><%= b.priest_name || '-' %></td>
              <td data-label="الفئة">
                <% if (b.category) { %>
                  <span class="badge" style="background:var(--gold-light);color:var(--gold-dark);"><%= b.category %></span>
                <% } else { %><span class="text-muted">-</span><% } %>
              </td>
              <td class="text-center fw-700" data-label="العدد"><%= b.num_people || 0 %></td>
              <td data-label="المدفوع">
                <span class="fw-700" style="color:#1B5E20;"><%= (b.paid_amount||0).toLocaleString() %></span>
                <small class="text-muted"> ج</small>
              </td>
              <td data-label="المتبقي">
                <span class="fw-700" style="color:<%= (b.remaining_amount||0) > 0 ? '#B71C1C' : '#9E9E9E' %>;">
                  <%= (b.remaining_amount||0).toLocaleString() %>
                </span>
                <small class="text-muted"> ج</small>
              </td>
              <td data-label="الحالة">
                <% if (b.status === 'confirmed') { %>
                  <span class="badge" style="background:#E8F5E9;color:#2E7D32;"><i class="bi bi-check-circle-fill me-1"></i>مؤكد</span>
                <% } else if (b.status === 'pending') { %>
                  <span class="badge" style="background:#FFF8E1;color:#F57F17;"><i class="bi bi-hourglass-split me-1"></i>انتظار</span>
                <% } else { %>
                  <span class="badge" style="background:#F5F5F5;color:#757575;"><i class="bi bi-x-circle me-1"></i>ملغي</span>
                <% } %>
              </td>
              <td class="td-actions">
                <div class="d-flex gap-1">
                  <% if (b.status === 'pending') { %>
                  <form action="/bookings/<%= b.id %>/approve" method="POST">
                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-2" title="موافقة">
                      <i class="bi bi-check-lg"></i>
                    </button>
                  </form>
                  <form action="/bookings/<%= b.id %>/reject" method="POST"
                    onsubmit="return confirm('رفض طلب <%= b.church_name %>؟')">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2" title="رفض">
                      <i class="bi bi-x-lg"></i>
                    </button>
                  </form>
                  <% } %>
                  <a href="/bookings/<%= b.id %>" class="btn btn-sm rounded-pill px-2" style="background:var(--gold-light);color:var(--gold-dark);" title="عرض">
                    <i class="bi bi-eye"></i>
                  </a>
                  <a href="/bookings/<%= b.id %>/edit" class="btn btn-sm btn-outline-secondary rounded-pill px-2" title="تعديل">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form action="/bookings/<%= b.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('هل تريد حذف حجز <%= b.church_name %>؟')">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2" title="حذف">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <div class="card-footer" style="background:var(--cream);border-top:1.5px solid var(--border);padding:10px 16px;">
      <small class="text-muted fw-semibold">
        <i class="bi bi-list-ul me-1"></i>عدد النتائج: <strong><%= bookings.length %></strong>
      </small>
    </div>
  </div>

  <!-- ===== كروت (موبايل / تابلت) ===== -->
  <div class="bk-list d-lg-none">
    <% bookings.forEach(b => { const ti = typeInfo(b.booking_type); %>
    <div class="bk-card <%= b._when || '' %>">
      <div class="bk-card-head">
        <div>
          <div class="bk-church"><%= b.church_name %></div>
          <% if (b.sector_name) { %><div class="bk-sector"><%= b.sector_name %></div><% } %>
        </div>
        <div class="text-start" style="flex-shrink:0;">
          <% if (b.status === 'confirmed') { %>
            <span class="badge" style="background:#E8F5E9;color:#2E7D32;"><i class="bi bi-check-circle-fill me-1"></i>مؤكد</span>
          <% } else if (b.status === 'pending') { %>
            <span class="badge" style="background:#FFF8E1;color:#F57F17;"><i class="bi bi-hourglass-split me-1"></i>انتظار</span>
          <% } else { %>
            <span class="badge" style="background:#F5F5F5;color:#757575;"><i class="bi bi-x-circle me-1"></i>ملغي</span>
          <% } %>
        </div>
      </div>

      <div class="bk-meta">
        <span class="badge" style="background:<%= ti.bg %>;color:<%= ti.color %>;"><i class="bi <%= ti.icon %> me-1"></i><%= ti.label %></span>
        <% if (b._when === 'today') { %>
          <span class="badge when-today"><i class="bi bi-bell-fill me-1"></i>النهاردة</span>
        <% } else if (b._when === 'past') { %>
          <span class="badge when-past"><i class="bi bi-check2-all me-1"></i>خلص</span>
        <% } else if (b._when === 'upcoming') { %>
          <span class="badge when-upcoming"><i class="bi bi-hourglass-top me-1"></i>قادم</span>
        <% } %>
        <span class="booking-num"><%= b.booking_number %></span>
        <% if (b.source === 'form') { %>
          <span class="badge" style="background:#EDE0FF;color:#6A0DAD;font-size:0.68rem;">أونلاين</span>
        <% } %>
      </div>

      <div class="bk-grid">
        <div class="cell">
          <label>التاريخ</label>
          <span class="val">
            <% if (isStayType(b.booking_type) && b.start_date) { %>
              <%= b.start_date %><% if (b.end_date) { %> ← <%= b.end_date %><% } %>
            <% } else if (b.event_date) { %>
              <%= b.event_date %><% if (b.start_time) { %> · <%= b.start_time %><% } %>
            <% } else { %>-<% } %>
          </span>
        </div>
        <div class="cell"><label>الكاهن</label><span class="val"><%= b.priest_name || '-' %></span></div>
        <div class="cell"><label>الفئة</label><span class="val"><%= b.category || '-' %></span></div>
        <div class="cell"><label>العدد</label><span class="val"><%= b.num_people || 0 %></span></div>
        <div class="cell"><label>المدفوع</label><span class="val" style="color:#1B5E20;"><%= (b.paid_amount||0).toLocaleString() %> ج</span></div>
        <div class="cell"><label>المتبقي</label><span class="val" style="color:<%= (b.remaining_amount||0) > 0 ? '#B71C1C' : '#9E9E9E' %>;"><%= (b.remaining_amount||0).toLocaleString() %> ج</span></div>
      </div>

      <div class="bk-actions">
        <% if (b.status === 'pending') { %>
        <form action="/bookings/<%= b.id %>/approve" method="POST">
          <button type="submit" class="btn btn-success" title="موافقة"><i class="bi bi-check-lg"></i></button>
        </form>
        <form action="/bookings/<%= b.id %>/reject" method="POST" onsubmit="return confirm('رفض طلب <%= b.church_name %>؟')">
          <button type="submit" class="btn btn-outline-danger" title="رفض"><i class="bi bi-x-lg"></i></button>
        </form>
        <% } %>
        <a href="/bookings/<%= b.id %>" class="btn" style="background:var(--gold-light);color:var(--gold-dark);" title="عرض"><i class="bi bi-eye"></i></a>
        <a href="/bookings/<%= b.id %>/edit" class="btn btn-outline-secondary" title="تعديل"><i class="bi bi-pencil"></i></a>
        <form action="/bookings/<%= b.id %>?_method=DELETE" method="POST" onsubmit="return confirm('هل تريد حذف حجز <%= b.church_name %>؟')">
          <button type="submit" class="btn btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
        </form>
      </div>
    </div>
    <% }) %>
    <div class="text-muted small fw-semibold mb-3 px-1">
      <i class="bi bi-list-ul me-1"></i>عدد النتائج: <strong><%= bookings.length %></strong>
    </div>
  </div>

  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
