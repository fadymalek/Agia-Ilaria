<%- include('../partials/head', { title: 'الحجوزات' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid py-4 px-4 fade-up">
  <%- include('../partials/flash') %>

  <!-- Page Header -->
  <div class="page-header">
    <h1 class="page-title"><i class="bi bi-calendar-check"></i>لوحة الحجوزات</h1>
    <div class="d-flex gap-2">
      <a href="/bookings/new?type=retreat" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-moon-stars-fill me-1"></i>خلوة جديدة
      </a>
      <a href="/bookings/new?type=spiritual_day" class="btn btn-success rounded-pill px-4">
        <i class="bi bi-brightness-high-fill me-1"></i>يوم روحي
      </a>
    </div>
  </div>

  <!-- Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#C4963A,#8B6914);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#FFF3E0;">
            <i class="bi bi-calendar3" style="color:#C4963A;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#C4963A,#8B6914);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.total %>
          </div>
          <div class="stat-label">إجمالي الحجوزات</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#1565C0,#0D47A1);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#E3F2FD;">
            <i class="bi bi-moon-stars-fill" style="color:#1565C0;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#1565C0,#0D47A1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.retreat %>
          </div>
          <div class="stat-label">خلوات روحية</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#2E7D32,#1B5E20);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#E8F5E9;">
            <i class="bi bi-brightness-high-fill" style="color:#2E7D32;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#2E7D32,#1B5E20);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.spiritual %>
          </div>
          <div class="stat-label">أيام روحية</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-lg-3">
      <div class="card stat-card">
        <div class="stat-accent" style="background:linear-gradient(90deg,#F57F17,#E65100);"></div>
        <div class="card-body text-center py-4">
          <div class="stat-icon-wrap mx-auto" style="background:#FFF8E1;">
            <i class="bi bi-clock-history" style="color:#F57F17;"></i>
          </div>
          <div class="stat-num" style="background:linear-gradient(135deg,#F57F17,#E65100);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
            <%= stats.pending %>
          </div>
          <div class="stat-label">في الانتظار</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Filter -->
  <div class="card filter-card mb-4">
    <div class="card-body">
      <form method="GET" action="/bookings" class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label">بحث</label>
          <div class="position-relative">
            <i class="bi bi-search position-absolute" style="right:12px;top:50%;transform:translateY(-50%);color:#BBA880;z-index:5;"></i>
            <input type="text" class="form-control" name="search" value="<%= query.search || '' %>"
              placeholder="كنيسة، كاهن، رقم حجز..." style="padding-right:38px;">
          </div>
        </div>
        <div class="col-md-2">
          <label class="form-label">النوع</label>
          <select class="form-select" name="type">
            <option value="">الكل</option>
            <option value="retreat" <%= query.type==='retreat'?'selected':'' %>>خلوة</option>
            <option value="spiritual_day" <%= query.type==='spiritual_day'?'selected':'' %>>يوم روحي</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">الحالة</label>
          <select class="form-select" name="status">
            <option value="">الكل</option>
            <option value="confirmed" <%= query.status==='confirmed'?'selected':'' %>>مؤكد</option>
            <option value="pending" <%= query.status==='pending'?'selected':'' %>>انتظار</option>
            <option value="cancelled" <%= query.status==='cancelled'?'selected':'' %>>ملغي</option>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label">من تاريخ</label>
          <input type="date" class="form-control" name="from" value="<%= query.from || '' %>">
        </div>
        <div class="col-md-2">
          <label class="form-label">إلى تاريخ</label>
          <input type="date" class="form-control" name="to" value="<%= query.to || '' %>">
        </div>
        <div class="col-md-1">
          <div class="d-flex gap-1">
            <button type="submit" class="btn btn-gold flex-fill" title="بحث"><i class="bi bi-search"></i></button>
            <a href="/bookings" class="btn btn-outline-secondary flex-fill" title="مسح"><i class="bi bi-x-lg"></i></a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Quick Links to public forms -->
  <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <small class="text-muted fw-semibold me-1"><i class="bi bi-share me-1"></i>روابط الحجز للكنائس:</small>
    <a href="/forms/retreat" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3">
      <i class="bi bi-moon-stars me-1"></i>فورم خلوة
    </a>
    <a href="/forms/spiritual-day" target="_blank" class="btn btn-sm btn-outline-success rounded-pill px-3">
      <i class="bi bi-sun me-1"></i>فورم يوم روحي
    </a>
    <a href="/reports" class="btn btn-sm btn-outline-secondary rounded-pill px-3 ms-auto">
      <i class="bi bi-bar-chart-line me-1"></i>التقرير الأسبوعي
    </a>
  </div>

  <!-- Table -->
  <div class="card">
    <div class="card-body p-0">
      <% if (bookings.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <i class="bi bi-inbox" style="font-size:3rem;color:#D4B870;"></i>
          <p class="mt-3 mb-1 fw-semibold">لا توجد حجوزات</p>
          <small>ابدأ بإضافة حجز جديد</small>
        </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table mb-0">
          <thead>
            <tr>
              <th class="pe-3">رقم الحجز</th>
              <th>اسم الكنيسة</th>
              <th>النوع</th>
              <th>التاريخ</th>
              <th>الكاهن</th>
              <th>الفئة</th>
              <th class="text-center">العدد</th>
              <th>المدفوع</th>
              <th>المتبقي</th>
              <th>الحالة</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% bookings.forEach(b => { %>
            <tr>
              <td class="pe-3">
                <span class="booking-num"><%= b.booking_number %></span>
                <% if (b.source === 'form') { %>
                  <br><span class="badge mt-1" style="background:#EDE0FF;color:#6A0DAD;font-size:0.68rem;">أونلاين</span>
                <% } %>
              </td>
              <td>
                <div class="fw-700" style="font-size:0.9rem;"><%= b.church_name %></div>
                <% if (b.sector_name) { %><div class="text-muted" style="font-size:0.76rem;"><%= b.sector_name %></div><% } %>
              </td>
              <td>
                <% if (b.booking_type === 'retreat') { %>
                  <span class="badge" style="background:#E3F2FD;color:#1565C0;">
                    <i class="bi bi-moon-stars-fill me-1"></i>خلوة
                  </span>
                <% } else { %>
                  <span class="badge" style="background:#E8F5E9;color:#2E7D32;">
                    <i class="bi bi-brightness-high-fill me-1"></i>يوم روحي
                  </span>
                <% } %>
              </td>
              <td style="font-size:0.83rem;">
                <% if (b.booking_type === 'retreat' && b.start_date) { %>
                  <div><i class="bi bi-calendar2 me-1 text-muted"></i><%= b.start_date %></div>
                  <div class="text-muted"><i class="bi bi-arrow-left me-1"></i><%= b.end_date || '' %></div>
                <% } else if (b.event_date) { %>
                  <div><i class="bi bi-calendar2 me-1 text-muted"></i><%= b.event_date %></div>
                  <% if (b.start_time) { %>
                    <div class="text-muted" style="font-size:0.78rem;"><i class="bi bi-clock me-1"></i><%= b.start_time %>-<%= b.end_time||'' %></div>
                  <% } %>
                <% } else { %><span class="text-muted">-</span><% } %>
              </td>
              <td style="font-size:0.87rem;"><%= b.priest_name || '-' %></td>
              <td>
                <% if (b.category) { %>
                  <span class="badge" style="background:var(--gold-light);color:var(--gold-dark);"><%= b.category %></span>
                <% } else { %><span class="text-muted">-</span><% } %>
              </td>
              <td class="text-center fw-700"><%= b.num_people || 0 %></td>
              <td>
                <span class="fw-700" style="color:#1B5E20;"><%= (b.paid_amount||0).toLocaleString() %></span>
                <small class="text-muted"> ج</small>
              </td>
              <td>
                <span class="fw-700" style="color:<%= (b.remaining_amount||0) > 0 ? '#B71C1C' : '#9E9E9E' %>;">
                  <%= (b.remaining_amount||0).toLocaleString() %>
                </span>
                <small class="text-muted"> ج</small>
              </td>
              <td>
                <% if (b.status === 'confirmed') { %>
                  <span class="badge" style="background:#E8F5E9;color:#2E7D32;"><i class="bi bi-check-circle-fill me-1"></i>مؤكد</span>
                <% } else if (b.status === 'pending') { %>
                  <span class="badge" style="background:#FFF8E1;color:#F57F17;"><i class="bi bi-hourglass-split me-1"></i>انتظار</span>
                <% } else { %>
                  <span class="badge" style="background:#F5F5F5;color:#757575;"><i class="bi bi-x-circle me-1"></i>ملغي</span>
                <% } %>
              </td>
              <td>
                <div class="d-flex gap-1">
                  <a href="/bookings/<%= b.id %>" class="btn btn-sm rounded-pill px-2" style="background:var(--gold-light);color:var(--gold-dark);" title="عرض">
                    <i class="bi bi-eye"></i>
                  </a>
                  <a href="/bookings/<%= b.id %>/edit" class="btn btn-sm btn-outline-secondary rounded-pill px-2" title="تعديل">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <form action="/bookings/<%= b.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('هل تريد حذف حجز <%= b.church_name %>؟')">
                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2" title="حذف">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
    <% if (bookings.length > 0) { %>
    <div class="card-footer" style="background:var(--cream);border-top:1.5px solid var(--border);padding:10px 16px;">
      <small class="text-muted fw-semibold">
        <i class="bi bi-list-ul me-1"></i>عدد النتائج: <strong><%= bookings.length %></strong>
      </small>
    </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
