<%- include('../partials/head', { title: 'حجز جديد' }) %>
<%- include('../partials/navbar') %>

<div class="container py-5" style="max-width:900px;">
  <div class="text-center mb-5 fade-up">
    <h3 class="fw-800 mb-2" style="color:var(--text);">اختر نوع الحجز</h3>
    <p class="text-muted">حدد نوع النشاط الروحي للمتابعة وتسجيل الحجز</p>
  </div>

  <div class="row g-4 justify-content-center fade-up">
    <!-- Retreat -->
    <div class="col-md-5">
      <a href="/bookings/new?type=retreat" class="text-decoration-none d-block">
        <div class="card type-selector-card retreat text-center p-4 h-100">
          <div class="type-icon-bg mx-auto" style="background:linear-gradient(135deg,#E3F2FD,#BBDEFB);">
            <i class="bi bi-moon-stars-fill" style="color:#1565C0;"></i>
          </div>
          <h4 class="fw-800 mb-2" style="color:#1565C0;">خلوة روحية</h4>
          <p class="text-muted small mb-3">إقامة لعدة أيام بالبيت الروحي</p>
          <ul class="list-unstyled text-start mb-4 px-2">
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>تحديد فترة الخلوة (من/إلى)</li>
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>اختيار الدور المحجوز</li>
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>المرحلة العمرية للبنات</li>
            <li class="small"><i class="bi bi-check-circle-fill text-success me-2"></i>عدد الأيام تلقائي</li>
          </ul>
          <button class="btn btn-primary rounded-pill px-4 py-2 fw-700 mt-auto">
            <i class="bi bi-moon-stars me-2"></i>حجز خلوة
          </button>
        </div>
      </a>
    </div>

    <!-- Spiritual Day -->
    <div class="col-md-5">
      <a href="/bookings/new?type=spiritual_day" class="text-decoration-none d-block">
        <div class="card type-selector-card spiritual text-center p-4 h-100">
          <div class="type-icon-bg mx-auto" style="background:linear-gradient(135deg,#E8F5E9,#C8E6C9);">
            <i class="bi bi-brightness-high-fill" style="color:#2E7D32;"></i>
          </div>
          <h4 class="fw-800 mb-2" style="color:#2E7D32;">يوم روحي</h4>
          <p class="text-muted small mb-3">زيارة ليوم واحد بالبيت الروحي</p>
          <ul class="list-unstyled text-start mb-4 px-2">
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>تحديد التاريخ</li>
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>من الساعة / إلى الساعة</li>
            <li class="mb-1 small"><i class="bi bi-check-circle-fill text-success me-2"></i>نوع الخدمة</li>
            <li class="small"><i class="bi bi-check-circle-fill text-success me-2"></i>عدد الأفراد</li>
          </ul>
          <button class="btn btn-success rounded-pill px-4 py-2 fw-700 mt-auto">
            <i class="bi bi-brightness-high me-2"></i>حجز يوم روحي
          </button>
        </div>
      </a>
    </div>
  </div>

  <div class="text-center mt-4">
    <a href="/bookings" class="text-muted small text-decoration-none">
      <i class="bi bi-arrow-right me-1"></i>العودة للحجوزات
    </a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
