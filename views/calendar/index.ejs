<%- include('../partials/head', { title: 'التقويم' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid py-4 px-4 fade-up">
  <%- include('../partials/flash') %>

  <div class="page-header">
    <h1 class="page-title"><i class="bi bi-calendar3"></i>تقويم الحجوزات</h1>
    <a href="/bookings" class="btn btn-outline-secondary rounded-pill px-4">
      <i class="bi bi-list-ul me-1"></i>عرض القائمة
    </a>
  </div>

  <!-- مفتاح الألوان -->
  <div class="d-flex flex-wrap gap-3 mb-3 small fw-semibold">
    <span><i class="bi bi-circle-fill" style="color:#107C77;"></i> خلوة جماعية</span>
    <span><i class="bi bi-circle-fill" style="color:#9A4C6D;"></i> خلوة فردية</span>
    <span><i class="bi bi-circle-fill" style="color:#5E7D2E;"></i> يوم روحي</span>
    <span><i class="bi bi-circle-fill" style="color:#9E9E9E;"></i> ملغي</span>
    <span class="text-muted">⏳ = في الانتظار</span>
  </div>

  <div class="text-muted small mb-2 d-md-none">
    <i class="bi bi-arrows-move me-1"></i>اسحب التقويم يمين/شمال لرؤية باقي الأيام
  </div>
  <div class="card">
    <div class="card-body p-2 p-md-3">
      <div class="calendar-scroll">
        <div id="calendar" style="min-height:520px;"></div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@6.1.15/locales/ar.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const el = document.getElementById('calendar');
    if (!el || typeof FullCalendar === 'undefined') return;

    function isSmall() { return window.innerWidth < 768; }

    function toolbarFor(small) {
      return {
        start: small ? 'prev,next' : 'prev,next today',
        center: 'title',
        end: 'dayGridMonth,timeGridWeek,timeGridDay,listMonth'
      };
    }

    // عدد الأحداث الظاهرة قبل ظهور رابط "+N أخرى" — أقل على الموبايل عشان الشكل يفضل مرتب
    function maxEventsFor(small) { return small ? 2 : 3; }

    const calendar = new FullCalendar.Calendar(el, {
      locale: 'ar',
      direction: 'rtl',
      initialView: 'dayGridMonth',
      height: 'auto',
      expandRows: true,
      headerToolbar: toolbarFor(isSmall()),
      buttonText: { today: 'النهاردة', month: 'شهر', week: 'أسبوع', day: 'يوم', list: 'قائمة' },
      noEventsText: 'لا توجد حجوزات في هذا الشهر',
      events: '/calendar/events',
      eventDisplay: 'block',
      displayEventTime: true,
      nowIndicator: true,
      dayMaxEvents: maxEventsFor(isSmall()),        // يجمع الزيادة في "+N أخرى" بدل التكدس
      moreLinkText: n => '+' + n + ' أخرى',
      moreLinkClick: 'popover',                     // يفتح كل حجوزات اليوم في نافذة مرتبة
      eventOrder: 'start,-duration,title',
      fixedWeekCount: false,
      eventClick: function (info) {
        info.jsEvent.preventDefault();
        if (info.event.url) window.location.href = info.event.url;
      },
      datesSet: updateScrollClass
    });

    // السحب الأفقي يتفعّل فقط في عرض الشهر على الموبايل
    function updateScrollClass() {
      const wrap = el.closest('.calendar-scroll');
      if (!wrap) return;
      wrap.classList.toggle('month-scroll', calendar.view.type === 'dayGridMonth' && window.innerWidth < 768);
    }

    calendar.render();
    updateScrollClass();

    // شريط أدوات متجاوب حسب حجم الشاشة
    let small = isSmall();
    window.addEventListener('resize', function () {
      if (isSmall() !== small) {
        small = isSmall();
        calendar.setOption('headerToolbar', toolbarFor(small));
        calendar.setOption('dayMaxEvents', maxEventsFor(small));
        calendar.updateSize();
      }
      updateScrollClass();
    });
  });
</script>
</body>
</html>
