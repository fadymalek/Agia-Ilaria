<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>استمارة حجز خلوة - بيت القديسة ايلاريا</title>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .scope-group { display: flex; gap: .75rem; }
    .scope-group .btn {
      flex: 1; transition: all .15s ease; font-weight: 600;
      border-radius: 14px; border-width: 1.5px; padding: .7rem .5rem;
    }
    .scope-group .btn:hover { border-color: var(--gold); color: var(--gold-dark); }
    .scope-group .btn-check:checked + .btn {
      background: var(--gold-dark); border-color: var(--gold-dark); color: #fff;
      box-shadow: 0 5px 14px rgba(139,105,20,.30); transform: translateY(-2px);
    }
    @media (max-width: 400px) { .scope-group { flex-direction: column; } }
  </style>
</head>
<body style="background: linear-gradient(135deg, #f5e6c8 0%, #e8d5a3 100%); min-height: 100vh;">

<div class="container py-5" style="max-width: 700px;">
  <!-- Header -->
  <div class="text-center mb-4">
    <img src="/images/logo.png" height="150" alt="Logo" onerror="this.style.display='none'">
    <div class="small text-muted mt-1">بطريركية الأقباط الأرثوذكس - قطاع غرب الاسكندرية</div>
    <h5 class="fw-bold mt-2" style="color: var(--gold-dark);">بيت القديسة ايلاريا للخلوات الروحية للبنات</h5>
    <span class="badge fs-6 text-white" style="background:#107C77;">استمارة حجز خلوة جماعية</span>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i><%= error %></div>
  <% } %>

  <%- include('../partials/house-info') %>

  <div class="card border-0 shadow">
    <div class="card-body p-4">
      <form action="/forms/retreat" method="POST">
        <h6 class="fw-bold mb-3 pb-2 border-bottom" style="color: var(--gold-dark);">
          <i class="bi bi-church me-2"></i>بيانات الكنيسة
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">اسم القطاع</label>
            <input type="text" class="form-control" name="sector_name" placeholder="قطاع غرب الاسكندرية...">
          </div>
          <div class="col-md-6">
            <label class="form-label required-label">اسم الكنيسة</label>
            <input type="text" class="form-control" name="church_name" required placeholder="كنيسة...">
          </div>
          <div class="col-md-6">
            <label class="form-label">الكاهن المسؤل</label>
            <input type="text" class="form-control" name="priest_name" placeholder="أبونا...">
          </div>
          <div class="col-md-6">
            <label class="form-label">تليفون الكاهن</label>
            <input type="tel" class="form-control" name="priest_phone" dir="ltr" placeholder="01XXXXXXXXX">
          </div>
          <div class="col-md-6">
            <label class="form-label">اسم مشرفة الخلوة</label>
            <input type="text" class="form-control" name="supervisor_name">
          </div>
          <div class="col-md-6">
            <label class="form-label">تليفون المشرفة</label>
            <input type="tel" class="form-control" name="supervisor_phone" dir="ltr" placeholder="01XXXXXXXXX">
          </div>
        </div>

        <h6 class="fw-bold mb-3 pb-2 border-bottom" style="color: var(--gold-dark);">
          <i class="bi bi-calendar me-2"></i>تفاصيل الخلوة
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label class="form-label">المرحلة العمرية / السن</label>
            <input type="text" class="form-control" name="age_group" placeholder="إعدادي، خدام، ابتدائي...">
          </div>
          <div class="col-md-6">
            <label class="form-label required-label">عدد أفراد الخلوة</label>
            <input type="number" class="form-control" name="num_people" id="num_people" min="1" required placeholder="0" oninput="calcEstimate()">
          </div>
          <div class="col-md-4">
            <label class="form-label">عدد الليالي</label>
            <input type="number" class="form-control bg-light" name="num_days" min="1" id="num_days" placeholder="يُحسب تلقائياً" readonly>
          </div>
          <div class="col-md-4">
            <label class="form-label required-label">من تاريخ</label>
            <input type="date" class="form-control" name="start_date" id="start_date" required>
          </div>
          <div class="col-md-4">
            <label class="form-label required-label">إلى تاريخ</label>
            <input type="date" class="form-control" name="end_date" id="end_date" required>
          </div>
          <div class="col-md-6">
            <label class="form-label required-label">الدور المطلوب حجزه</label>
            <select class="form-select" name="floor_number" id="floor_number" onchange="calcEstimate()">
              <option value="">اختر الدور</option>
              <option value="الدور الأول">الدور الأول</option>
              <option value="الدور الثاني">الدور الثاني</option>
              <option value="الدور الثالث">الدور الثالث</option>
              <option value="كامل البيت">كامل البيت</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label required-label d-block">القطاع</label>
            <div class="scope-group" role="group" aria-label="القطاع">
              <input type="radio" class="btn-check" name="sector_scope" id="scope_in" value="inside" autocomplete="off">
              <label class="btn btn-outline-secondary" for="scope_in"><i class="bi bi-geo-alt-fill me-1"></i>داخل القطاع</label>
              <input type="radio" class="btn-check" name="sector_scope" id="scope_out" value="outside" autocomplete="off">
              <label class="btn btn-outline-secondary" for="scope_out"><i class="bi bi-pin-map-fill me-1"></i>خارج القطاع</label>
            </div>
          </div>
          <div class="col-12">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" role="switch" id="kitchen_included" name="kitchen_included" value="1" onchange="calcEstimate()">
              <label class="form-check-label" for="kitchen_included">هيتم استخدام المطبخ؟ (بيضاف على السعر لكل ليلة)</label>
            </div>
          </div>
        </div>

        <h6 class="fw-bold mb-3 pb-2 border-bottom" style="color: var(--gold-dark);">
          <i class="bi bi-cash-coin me-2"></i>التكلفة التقريبية
        </h6>
        <input type="hidden" name="total_amount" id="totalAmount">
        <div class="mb-4 p-3 rounded" style="background:#fffbf0; border:1px solid #e8d5a3;">
          <div id="estHint" class="text-muted">
            <i class="bi bi-info-circle me-1"></i>
            اختاري <strong>الدور</strong> و<strong>القطاع</strong> و<strong>عدد الأفراد</strong> و<strong>التواريخ</strong> عشان يظهر السعر التقريبي تلقائياً.
          </div>
          <div id="estContact" style="display:none;" class="fw-bold text-center py-2" >
            <i class="bi bi-telephone me-1" style="color:var(--gold-dark);"></i>
            <span style="color:var(--gold-dark);">السعر لهذا الاختيار بالتواصل مع إدارة البيت.</span>
          </div>
          <div id="estDetails" style="display:none;">
            <div class="d-flex align-items-center justify-content-between">
              <span class="fw-bold" style="color:var(--gold-dark);">الإجمالي التقريبي</span>
              <span id="estTotal" class="fw-bold fs-3" style="color:#107C77;">0 ج</span>
            </div>
            <div class="small text-muted mt-2">
              <i class="bi bi-exclamation-circle me-1"></i>
              الرقم ده <strong>تقريبي</strong> وممكن يزيد أو يقل على حسب عدد الأفراد الفعلي في كل ليلة.
            </div>
          </div>
        </div>

        <div class="mb-4 p-3 rounded" style="background: #fffbf0; border: 1px solid #e8d5a3;">
          <h6 class="fw-bold mb-2">إقرار</h6>
          <p class="small text-muted mb-2">
            أقر أنا ............... الموقع أدناه بأنني اطلعت على تعليمات البيت ومسؤل عن سلامته ونظافته والحفاظ على هدوئه طول أيام الخلوة.
          </p>
          <label class="form-label small">الاسم (للتوقيع)</label>
          <input type="text" class="form-control" name="signature_name">
        </div>

        <button type="submit" class="btn w-100 py-3 fw-bold fs-5 text-white" style="background:#107C77;">
          <i class="bi bi-send me-2"></i>إرسال طلب الحجز
        </button>
      </form>
    </div>
  </div>
</div>

<script>
// أسعار الليلة الواحدة (تُدار من لوحة الإدارة). الدور الثالث/كامل البيت => بالتواصل
const PRICING = <%- JSON.stringify(pricing.retreat) %>;

const $ = id => document.getElementById(id);
const fmt = n => Number(n).toLocaleString('en-US');

function nights() {
  const s = $('start_date').value, e = $('end_date').value;
  if (!s || !e) return 0;
  const d = (new Date(e) - new Date(s)) / 86400000;
  return d > 0 ? Math.round(d) : 0;
}
function scopeVal() {
  const r = document.querySelector('input[name="sector_scope"]:checked');
  return r ? r.value : '';
}

function calcEstimate() {
  const n = nights();
  if (n > 0) $('num_days').value = n;

  const floor = $('floor_number').value;
  const scope = scopeVal();
  const people = parseInt($('num_people').value) || 0;
  const kitchen = $('kitchen_included').checked;

  const hint = $('estHint'), details = $('estDetails'), contact = $('estContact');
  const hidden = $('totalAmount');
  const fp = PRICING[floor];

  // دور سعره صفر (زي الدور الثالث/كامل البيت لو ماتحطّش سعر) => السعر بالتواصل
  const unpriced = floor && (!fp ||
    ((!fp.inside || !(fp.inside.person > 0)) && (!fp.outside || !(fp.outside.person > 0))));
  if (unpriced) {
    hint.style.display = 'none'; details.style.display = 'none'; contact.style.display = 'block';
    hidden.value = '';
    return;
  }
  contact.style.display = 'none';

  if (!floor || !scope || !people || !n || !(fp[scope] && fp[scope].person > 0)) {
    hint.style.display = 'block'; details.style.display = 'none'; hidden.value = '';
    return;
  }

  const rate = fp[scope];
  const peopleCost = rate.person * people * n;
  const kitchenCost = kitchen ? rate.kitchen * n : 0;
  const total = peopleCost + kitchenCost;

  $('estTotal').textContent = fmt(total) + ' ج';
  hidden.value = total;

  hint.style.display = 'none'; details.style.display = 'block';
}

['start_date', 'end_date'].forEach(id => $(id).addEventListener('change', calcEstimate));
document.querySelectorAll('input[name="sector_scope"]').forEach(r => r.addEventListener('change', calcEstimate));
</script>
</body>
</html>
