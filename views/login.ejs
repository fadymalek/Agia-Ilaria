<%- include('partials/head', { title: 'تسجيل الدخول' }) %>

<div class="login-page">
  <div class="login-card card fade-up">
    <!-- Header -->
    <div class="login-header">
      <span class="login-logo-chip">
        <img src="/images/logo.png" alt="بيت القديسة ايلاريا" onerror="this.parentElement.style.display='none'">
      </span>
      <h5 class="text-white fw-800 mt-3 mb-1" style="font-size:1.2rem;">بيت القديسة ايلاريا</h5>
      <p class="text-white mb-0" style="opacity:0.75;font-size:0.82rem;">نظام إدارة الحجوزات الروحية</p>
    </div>

    <!-- Body -->
    <div class="login-body">
      <% if (error && error.length) { %>
        <div class="alert alert-danger mb-4 py-2">
          <i class="bi bi-exclamation-triangle-fill me-2"></i><%= error[0] %>
        </div>
      <% } %>

      <p class="text-muted small text-center mb-4">أدخل بيانات الدخول للمتابعة</p>

      <form action="/login" method="POST">
        <div class="mb-3">
          <label class="form-label">اسم المستخدم</label>
          <div class="login-icon-wrap">
            <i class="bi bi-person"></i>
            <input type="text" class="form-control" name="username" required autofocus
              placeholder="admin" style="padding-right:42px;">
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label">كلمة المرور</label>
          <div class="login-icon-wrap">
            <i class="bi bi-lock"></i>
            <input type="password" class="form-control" name="password" required
              placeholder="••••••••" style="padding-right:42px;">
          </div>
        </div>
        <button type="submit" class="btn btn-gold w-100 py-2 fw-700" style="font-size:1rem;border-radius:10px!important;">
          <i class="bi bi-box-arrow-in-right me-2"></i>دخول
        </button>
      </form>

      <div class="text-center mt-4 pt-3 border-top">
        <p class="text-muted small mb-0" style="font-size:0.78rem;">
          <i class="bi bi-shield-lock me-1"></i>بيت القديسة ايلاريا للخلوات الروحية للبنات - بأبو تلات
        </p>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
