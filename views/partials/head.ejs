<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>بيت القديسة ايلاريا</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- تطبيق تفضيلات العرض (الخط/الحجم) قبل رسم الصفحة لتفادي الوميض -->
  <script>
    (function () {
      try {
        var p = JSON.parse(localStorage.getItem('hilaria_prefs') || '{}');
        var root = document.documentElement;
        var FONTS = {
          plex: "'IBM Plex Sans Arabic'", cairo: "'Cairo'",
          tajawal: "'Tajawal'", almarai: "'Almarai'", amiri: "'Amiri'"
        };
        var GF = { cairo: 'Cairo:wght@400;500;600;700', tajawal: 'Tajawal:wght@400;500;700',
          almarai: 'Almarai:wght@400;700;800', amiri: 'Amiri:wght@400;700' };
        if (p.scale) root.style.setProperty('--fscale', p.scale);
        if (p.font && FONTS[p.font] && p.font !== 'plex') {
          root.style.setProperty('--font-sans', FONTS[p.font] + ", 'IBM Plex Sans Arabic', 'Segoe UI', Tahoma, sans-serif");
          if (GF[p.font]) {
            var l = document.createElement('link'); l.rel = 'stylesheet';
            l.href = 'https://fonts.googleapis.com/css2?family=' + GF[p.font] + '&display=swap';
            document.head.appendChild(l);
          }
        }
        if (p.contrast) root.classList.add('pref-contrast');
      } catch (e) {}
    })();
  </script>
</head>
<body>
