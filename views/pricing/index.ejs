<%- include('../partials/head', { title: 'الأسعار' }) %>
<%- include('../partials/navbar') %>

<style>
  .price-card { border:0; border-radius:16px; }
  .price-card .card-header { border:0; border-radius:16px 16px 0 0; font-weight:800; color:#fff; }
  .price-grid { display:grid; grid-template-columns: 1fr 1fr; gap:1rem; }
  @media (max-width: 600px){ .price-grid { grid-template-columns: 1fr; } }
  .price-sub { font-weight:700; color:var(--gold-dark); margin-bottom:.5rem; }
  .price-input .input-group-text { background:#faf6ec; font-weight:600; min-width:112px; }
</style>

<div class="container py-4 fade-up" style="max-width:820px;">
  <%- include('../partials/flash') %>

  <div class="d-flex align-items-center gap-3 mb-4">
    <a href="/bookings" class="btn btn-sm btn-outline-secondary rounded-circle" style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;">
      <i class="bi bi-arrow-right"></i>
    </a>
    <div>
      <h4 class="mb-0 fw-800"><i class="bi bi-tag-fill me-2" style="color:var(--gold);"></i>أسعار الحجز</h4>
      <small class="text-muted">غيّر الأسعار هنا وقت ما تحب — الفورمات هتحسب بالأسعار الجديدة فوراً.</small>
    </div>
  </div>

  <form action="/pricing" method="POST">

    <!-- الخلوة الجماعية -->
    <div class="card price-card shadow-sm mb-4">
      <div class="card-header" style="background:linear-gradient(135deg,#12a29b,#107C77);">
        <i class="bi bi-moon-stars-fill me-2"></i>الخلوة الجماعية — سعر الليلة الواحدة
      </div>
      <div class="card-body p-4">
        <div class="price-grid">
          <% [
            { key:'f1', title:'الدور الأول' },
            { key:'f2', title:'الدور الثاني' },
            { key:'f3', title:'الدور الثالث' },
            { key:'fh', title:'كامل البيت' }
          ].forEach(fl => {
            const p = pricing.retreat[fl.title] || { inside:{}, outside:{} };
          %>
          <div>
            <div class="price-sub"><i class="bi bi-building me-1"></i><%= fl.title %></div>
            <div class="mb-3">
              <div class="small text-muted mb-1"><i class="bi bi-geo-alt-fill me-1"></i>داخل القطاع</div>
              <div class="input-group price-input mb-2">
                <span class="input-group-text">الفرد / ليلة</span>
                <input type="number" min="0" step="1" class="form-control" name="<%= fl.key %>_in_person" value="<%= p.inside.person ?? '' %>">
                <span class="input-group-text">ج</span>
              </div>
              <div class="input-group price-input">
                <span class="input-group-text">المطبخ / ليلة</span>
                <input type="number" min="0" step="1" class="form-control" name="<%= fl.key %>_in_kitchen" value="<%= p.inside.kitchen ?? '' %>">
                <span class="input-group-text">ج</span>
              </div>
            </div>
            <div>
              <div class="small text-muted mb-1"><i class="bi bi-pin-map-fill me-1"></i>خارج القطاع</div>
              <div class="input-group price-input mb-2">
                <span class="input-group-text">الفرد / ليلة</span>
                <input type="number" min="0" step="1" class="form-control" name="<%= fl.key %>_out_person" value="<%= p.outside.person ?? '' %>">
                <span class="input-group-text">ج</span>
              </div>
              <div class="input-group price-input">
                <span class="input-group-text">المطبخ / ليلة</span>
                <input type="number" min="0" step="1" class="form-control" name="<%= fl.key %>_out_kitchen" value="<%= p.outside.kitchen ?? '' %>">
                <span class="input-group-text">ج</span>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <div class="alert mt-3 mb-0 py-2 px-3 small" style="background:#fffbf0;border:1px solid #e8d5a3;color:#8B6914;">
          <i class="bi bi-info-circle me-1"></i>
          أي دور تسيب سعره <strong>صفر</strong> الفورم هيقول فيه «السعر بالتواصل» — حط رقم عشان يتحسب تلقائي.
        </div>
      </div>
    </div>

    <!-- اليوم الروحي -->
    <div class="card price-card shadow-sm mb-4">
      <div class="card-header" style="background:linear-gradient(135deg,#7aa233,#5E7D2E);">
        <i class="bi bi-brightness-high-fill me-2"></i>اليوم الروحي — سعر الفرد
      </div>
      <div class="card-body p-4">
        <div class="price-grid">
          <div>
            <div class="small text-muted mb-1"><i class="bi bi-geo-alt-fill me-1"></i>داخل القطاع</div>
            <div class="input-group price-input">
              <span class="input-group-text">الفرد</span>
              <input type="number" min="0" step="1" class="form-control" name="sd_in" value="<%= pricing.spiritual_day.inside ?? '' %>">
              <span class="input-group-text">ج</span>
            </div>
          </div>
          <div>
            <div class="small text-muted mb-1"><i class="bi bi-pin-map-fill me-1"></i>خارج القطاع</div>
            <div class="input-group price-input">
              <span class="input-group-text">الفرد</span>
              <input type="number" min="0" step="1" class="form-control" name="sd_out" value="<%= pricing.spiritual_day.outside ?? '' %>">
              <span class="input-group-text">ج</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2 justify-content-end pb-4">
      <a href="/bookings" class="btn btn-outline-secondary px-4 rounded-pill"><i class="bi bi-x-circle me-1"></i>إلغاء</a>
      <button type="submit" class="btn btn-gold px-5 rounded-pill fw-700"><i class="bi bi-check-circle-fill me-2"></i>حفظ الأسعار</button>
    </div>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
