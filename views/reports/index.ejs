<%- include('../partials/head', { title: 'التقارير' }) %>
<%- include('../partials/navbar') %>

<div class="container-fluid py-4">
  <%- include('../partials/flash') %>

  <div class="d-flex align-items-center justify-content-between mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart me-2"></i>التقرير الأسبوعي</h4>
    <div class="d-flex gap-2 no-print">
      <a href="/reports/export?from=<%= from %>&to=<%= to %>" class="btn btn-success">
        <i class="bi bi-file-earmark-excel me-1"></i>تصدير Excel
      </a>
      <button onclick="window.print()" class="btn btn-outline-secondary">
        <i class="bi bi-printer me-1"></i>طباعة التقرير
      </button>
    </div>
  </div>

  <!-- Date Range Filter -->
  <div class="card border-0 shadow-sm mb-4 no-print">
    <div class="card-body">
      <form method="GET" action="/reports" class="row g-2 align-items-end">
        <div class="col-md-4">
          <label class="form-label fw-semibold">من تاريخ</label>
          <input type="date" class="form-control" name="from" value="<%= from %>">
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">إلى تاريخ</label>
          <input type="date" class="form-control" name="to" value="<%= to %>">
        </div>
        <div class="col-md-4">
          <button type="submit" class="btn btn-gold w-100">
            <i class="bi bi-search me-1"></i>عرض التقرير
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Summary Stats -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-3 text-primary"><%= totals.count %></div>
        <div class="small text-muted">إجمالي الحجوزات</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-3"><%= totals.retreat_count %></div>
        <div class="small text-muted">خلوات</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-3 text-success"><%= totals.spiritual_count %></div>
        <div class="small text-muted">أيام روحية</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-3 text-info"><%= totals.total_people %></div>
        <div class="small text-muted">إجمالي الأفراد</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-4 text-success"><%= totals.paid_amount.toLocaleString() %></div>
        <div class="small text-muted">المدفوع (ج.م)</div>
      </div>
    </div>
    <div class="col-6 col-md-2">
      <div class="card border-0 shadow-sm text-center p-3">
        <div class="fw-bold fs-4 text-danger"><%= totals.remaining_amount.toLocaleString() %></div>
        <div class="small text-muted">المتبقي (ج.م)</div>
      </div>
    </div>
  </div>

  <!-- Report Header for Print -->
  <div class="print-only text-center mb-3">
    <h5>بيت القديسة ايلاريا - التقرير الأسبوعي</h5>
    <p>الفترة من <%= from %> إلى <%= to %></p>
  </div>

  <!-- Bookings Table -->
  <div class="card border-0 shadow-sm">
    <div class="card-header fw-bold" style="background: var(--gold-light);">
      تفاصيل الحجوزات في الفترة من <strong><%= from %></strong> إلى <strong><%= to %></strong>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead style="background: #f8f9fa;">
            <tr>
              <th class="px-3">رقم الحجز</th>
              <th>اسم الكنيسة</th>
              <th>النوع</th>
              <th>التاريخ</th>
              <th>الكاهن</th>
              <th>الفئة</th>
              <th>العدد</th>
              <th>الإجمالي</th>
              <th>المدفوع</th>
              <th>المتبقي</th>
              <th>الحالة</th>
            </tr>
          </thead>
          <tbody>
            <% if (bookings.length === 0) { %>
              <tr><td colspan="11" class="text-center text-muted py-4">لا توجد حجوزات في هذه الفترة</td></tr>
            <% } %>
            <% bookings.forEach(b => { %>
              <tr>
                <td class="px-3 small font-monospace"><%= b.booking_number %></td>
                <td class="fw-semibold"><%= b.church_name %></td>
                <td>
                  <% const ti = typeInfo(b.booking_type); %>
                  <span class="badge" style="background:<%= ti.bg %>;color:<%= ti.color %>;"><%= ti.label %></span>
                </td>
                <td class="small">
                  <% if (isStayType(b.booking_type) && b.start_date) { %>
                    <%= b.start_date %><br><small class="text-muted">→ <%= b.end_date || '' %></small>
                  <% } else { %>
                    <%= b.event_date || '-' %>
                    <% if (b.start_time) { %><br><small class="text-muted"><%= b.start_time %>-<%= b.end_time || '' %></small><% } %>
                  <% } %>
                </td>
                <td class="small"><%= b.priest_name || '-' %></td>
                <td class="small"><%= b.category || '-' %></td>
                <td class="text-center"><%= b.num_people || 0 %></td>
                <td class="small"><%= (b.total_amount || 0).toLocaleString() %></td>
                <td class="text-success small fw-semibold"><%= (b.paid_amount || 0).toLocaleString() %></td>
                <td class="<%= (b.remaining_amount || 0) > 0 ? 'text-danger' : 'text-muted' %> small fw-semibold">
                  <%= (b.remaining_amount || 0).toLocaleString() %>
                </td>
                <td>
                  <% if (b.status === 'confirmed') { %><span class="badge bg-success">مؤكد</span>
                  <% } else if (b.status === 'pending') { %><span class="badge bg-warning text-dark">انتظار</span>
                  <% } else { %><span class="badge bg-secondary">ملغي</span><% } %>
                </td>
              </tr>
            <% }) %>
            <% if (bookings.length > 0) { %>
            <tr class="table-active fw-bold">
              <td colspan="6" class="px-3 text-end">الإجمالي:</td>
              <td class="text-center"><%= totals.total_people %></td>
              <td><%= totals.total_amount.toLocaleString() %></td>
              <td class="text-success"><%= totals.paid_amount.toLocaleString() %></td>
              <td class="text-danger"><%= totals.remaining_amount.toLocaleString() %></td>
              <td></td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
