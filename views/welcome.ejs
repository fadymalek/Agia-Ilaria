<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>بيت القديسة ايلاريا للخلوات الروحية للبنات</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* ===== خلفية متدرّجة متحركة ===== */
    body {
      min-height: 100vh;
      background: linear-gradient(-45deg, #f7ecd0, #e8d5a3, #f3e0b0, #efd6a0, #f5e6c8);
      background-size: 400% 400%;
      animation: gradientShift 18s ease infinite;
      overflow-x: hidden;
      position: relative;
    }
    @keyframes gradientShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    /* دوائر زخرفية طايفة في الخلفية */
    .blob { position: fixed; border-radius: 50%; filter: blur(6px); opacity: .28; z-index: 0; pointer-events: none; }
    .blob-1 { width: 260px; height: 260px; background: #d9b56a; top: -80px; inset-inline-start: -60px; animation: float1 14s ease-in-out infinite; }
    .blob-2 { width: 200px; height: 200px; background: #c99a3f; bottom: -60px; inset-inline-end: -40px; animation: float2 16s ease-in-out infinite; }
    @keyframes float1 { 0%,100%{ transform: translate(0,0);} 50%{ transform: translate(30px,40px);} }
    @keyframes float2 { 0%,100%{ transform: translate(0,0);} 50%{ transform: translate(-35px,-30px);} }

    .content { position: relative; z-index: 1; }

    /* ===== ظهور تدريجي للعناصر ===== */
    .reveal { opacity: 0; transform: translateY(18px); animation: fadeUp .7s ease forwards; }
    .reveal.d1 { animation-delay: .05s; }
    .reveal.d2 { animation-delay: .18s; }
    .reveal.d3 { animation-delay: .31s; }
    .reveal.d4 { animation-delay: .44s; }
    .reveal.d5 { animation-delay: .57s; }
    @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }

    .welcome-logo {
      height: 190px; filter: drop-shadow(0 8px 16px rgba(92,61,10,.22));
      animation: logoIn 1s ease .1s both, bob 5s ease-in-out 1.1s infinite;
    }
    @keyframes logoIn { from { opacity:0; transform: scale(.85); } to { opacity:1; transform: scale(1); } }
    @keyframes bob { 0%,100%{ transform: translateY(0);} 50%{ transform: translateY(-8px);} }

    /* ===== كروت الاختيار ===== */
    .choice-card {
      display: block; text-decoration: none; color: #fff; border-radius: 18px;
      padding: 1.6rem 1.25rem; text-align: center; height: 100%; position: relative; overflow: hidden;
      box-shadow: 0 8px 22px rgba(92,61,10,.18); transition: transform .18s ease, box-shadow .18s ease;
    }
    .choice-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 16px 34px rgba(92,61,10,.30); color:#fff; }
    .choice-card .ci { font-size: 2.6rem; display:block; margin-bottom:.5rem; transition: transform .25s ease; }
    .choice-card:hover .ci { transform: scale(1.12) rotate(-4deg); }
    .choice-card .ct { font-size: 1.35rem; font-weight: 700; }
    .choice-card .cs { font-size: .9rem; opacity: .92; }
    .choice-retreat { background: linear-gradient(140deg, #12a29b 0%, #107C77 100%); }
    .choice-spiritual { background: linear-gradient(140deg, #7aa233 0%, #5E7D2E 100%); }
    /* لمعة تمر على الكارت عند المرور */
    .choice-card::before {
      content: ""; position: absolute; top: 0; inset-inline-start: -60%; width: 40%; height: 100%;
      background: linear-gradient(120deg, transparent, rgba(255,255,255,.35), transparent);
      transform: skewX(-20deg); transition: inset-inline-start .5s ease;
    }
    .choice-card:hover::before { inset-inline-start: 120%; }

    .intro-card { border:0; border-radius:18px; }

    /* ===== بوكس مشاركة الرابط ===== */
    .share-box {
      border: 2px dashed var(--gold); border-radius: 18px; background: #fffdf7;
      box-shadow: 0 6px 18px rgba(196,150,58,.15); position: relative; overflow: hidden;
    }
    .share-box::after {
      content: ""; position: absolute; inset: 0;
      background: radial-gradient(circle at 100% 0, rgba(196,150,58,.10), transparent 45%);
      pointer-events: none;
    }
    .share-url {
      direction: ltr; text-align: left; font-size: .92rem; background:#fff;
      border:1px solid #eadfc4; border-radius: 10px; padding:.55rem .75rem; color:#6b5a2e;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .btn-copy {
      background: linear-gradient(140deg, #d3a545, var(--gold-dark)); color:#fff; border:0;
      border-radius: 10px; font-weight: 700; white-space: nowrap; transition: transform .12s ease, filter .12s ease;
    }
    .btn-copy:hover { filter: brightness(1.06); color:#fff; }
    .btn-copy:active { transform: scale(.96); }
    .btn-copy.copied { background: linear-gradient(140deg, #4caf7d, #2e7d52); }
    .pulse { animation: pulse .45s ease; }
    @keyframes pulse { 0%{ transform: scale(1);} 40%{ transform: scale(1.14);} 100%{ transform: scale(1);} }

    /* توست النسخ */
    .copy-toast {
      position: fixed; bottom: 24px; inset-inline-start: 50%; transform: translateX(50%) translateY(20px);
      background: #2e7d52; color:#fff; padding:.6rem 1.1rem; border-radius: 12px; font-weight:600;
      box-shadow: 0 8px 24px rgba(0,0,0,.2); opacity: 0; pointer-events: none;
      transition: opacity .3s ease, transform .3s ease; z-index: 50;
    }
    .copy-toast.show { opacity: 1; transform: translateX(50%) translateY(0); }

    @media (prefers-reduced-motion: reduce) {
      body { animation: none; }
      .blob, .reveal, .welcome-logo { animation: none !important; opacity: 1; transform: none; }
    }
  </style>
</head>
<body>

<div class="blob blob-1"></div>
<div class="blob blob-2"></div>

<div class="container content py-5" style="max-width: 760px;">

  <!-- Header -->
  <div class="text-center mb-4">
    <img src="/images/logo.png" class="welcome-logo" alt="بيت القديسة ايلاريا" onerror="this.style.display='none'">
    <div class="small text-muted mt-2 reveal d1">بطريركية الأقباط الأرثوذكس — قطاع غرب الاسكندرية</div>
    <h4 class="fw-bold mt-2 reveal d1" style="color: var(--gold-dark);">بيت القديسة إيلارية للخلوات الروحية — للبنات</h4>
    <div class="text-muted reveal d2">بأبو تلات</div>
  </div>

  <!-- تعريف بالبيت -->
  <div class="card intro-card shadow-sm mb-4 reveal d2">
    <div class="card-body p-4 text-center">
      <h6 class="fw-bold mb-2" style="color: var(--gold-dark);">
        <i class="bi bi-stars me-1"></i> أهلاً بيكم في بيت أجيا إيلاريا
      </h6>
      <p class="mb-0 text-secondary" style="line-height: 2;">
        بيت مخصّص <strong>للخلوات الروحية للبنات</strong> — من سنّ الإعدادي حتى الخريجات والخادمات والسيدات،
        ويقبل كذلك رحلات <strong>اليوم الواحد (اليوم الروحي)</strong> من 8 صباحًا إلى 8 مساءً.
        البيت للخلوة الروحية والهدوء والصلاة، وليس للمعسكرات الترفيهية.
        اختاري نوع الحجز المناسب لبدء تسجيل طلبك.
      </p>
    </div>
  </div>

  <!-- الاختيارين -->
  <div class="row g-3 mb-4">
    <div class="col-12 col-md-6 reveal d3">
      <a href="/forms/retreat" class="choice-card choice-retreat">
        <i class="bi bi-house-heart ci"></i>
        <span class="ct">حجز خلوة جماعية</span>
        <span class="cs d-block mt-1">إقامة لعدة أيام لمجموعة من الكنيسة</span>
      </a>
    </div>
    <div class="col-12 col-md-6 reveal d3">
      <a href="/forms/spiritual-day" class="choice-card choice-spiritual">
        <i class="bi bi-sun ci"></i>
        <span class="ct">حجز يوم روحي</span>
        <span class="cs d-block mt-1">رحلة اليوم الواحد من 8 ص إلى 8 م</span>
      </a>
    </div>
  </div>

  <!-- بوكس مشاركة رابط الحجز -->
  <div class="share-box p-3 p-md-4 mb-4 reveal d4">
    <div class="d-flex align-items-center mb-2" style="color: var(--gold-dark);">
      <i class="bi bi-share-fill me-2 fs-5"></i>
      <span class="fw-bold">رابط صفحة الحجز — انسخه وابعته للناس</span>
    </div>
    <div class="row g-2 align-items-center">
      <div class="col">
        <div class="share-url" id="shareUrl">…</div>
      </div>
      <div class="col-auto">
        <button type="button" class="btn btn-copy px-3 py-2" id="copyBtn" onclick="copyLink()">
          <i class="bi bi-clipboard me-1" id="copyIcon"></i><span id="copyText">نسخ الرابط</span>
        </button>
      </div>
    </div>
    <div class="small text-muted mt-2">
      <i class="bi bi-info-circle me-1"></i>
      اللي هيفتح الرابط ده هيوصل للصفحة دي ويقدر يختار «خلوة جماعية» أو «يوم روحي» ويملأ الاستمارة.
    </div>
  </div>

  <!-- التعليمات ونظام البيت -->
  <div class="reveal d5">
    <%- include('partials/house-info') %>
  </div>

  <!-- تذييل -->
  <div class="text-center mt-4 reveal d5">
    <a href="/login" class="text-muted small text-decoration-none">
      <i class="bi bi-shield-lock me-1"></i> دخول المشرفين / الإدارة
    </a>
  </div>

</div>

<div class="copy-toast" id="copyToast"><i class="bi bi-check-circle-fill me-1"></i> تم نسخ الرابط ✅</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // الرابط اللي هيتشارك = رابط الصفحة الحالية (الجذر) على نفس الدومين
  var shareLink = window.location.origin + '/';
  document.getElementById('shareUrl').textContent = shareLink;

  function showToast() {
    var t = document.getElementById('copyToast');
    t.classList.add('show');
    clearTimeout(window.__toastT);
    window.__toastT = setTimeout(function () { t.classList.remove('show'); }, 2200);
  }

  function markCopied() {
    var btn = document.getElementById('copyBtn');
    var icon = document.getElementById('copyIcon');
    var txt = document.getElementById('copyText');
    btn.classList.add('copied', 'pulse');
    icon.className = 'bi bi-check-lg me-1';
    txt.textContent = 'تم النسخ';
    showToast();
    setTimeout(function () {
      btn.classList.remove('copied', 'pulse');
      icon.className = 'bi bi-clipboard me-1';
      txt.textContent = 'نسخ الرابط';
    }, 2200);
  }

  function copyLink() {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(shareLink).then(markCopied).catch(fallbackCopy);
    } else {
      fallbackCopy();
    }
  }

  function fallbackCopy() {
    var ta = document.createElement('textarea');
    ta.value = shareLink;
    ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.select();
    try { document.execCommand('copy'); markCopied(); } catch (e) {}
    document.body.removeChild(ta);
  }
</script>
</body>
</html>
